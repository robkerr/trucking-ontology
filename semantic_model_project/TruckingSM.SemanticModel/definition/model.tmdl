model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - lh_trucking"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["RemoteModeling","DirectLakeOnOneLakeCreatedInDesktop","DevMode","DirectLakeOnOneLakeInWeb","WebModelingEdit"]

ref table terminals
ref table customers
ref table trucks
ref table trailers
ref table drivers
ref table routes
ref table loads
ref table trips

